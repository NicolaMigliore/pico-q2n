-- pickups
function new_pickup(x,y)
	return{
		x=x,y=y,w=8,
		a={idle={24,25,26,27,28,29,30}},
		ai=rnd({1,2,3}),as=.2,
		s='idle',
		
		col_shape='circle',
		col_func=function(s,o)
			pts+=1
			--mark for deletion
			s.del=true
		end,
		
		u=function()end,
		
		d=function(s)
			local f=s.a.idle[flr(s.ai)]
			sprc(f,s.x,s.y,8,8,1)
		end
	}
end
